# این فایل را به .env کپی کنید و مقادیر را تنظیم کنید:
#   cp .env.example .env

# رمز عبور صفحه‌ی مدیریت (/admin) — حتماً یک رمز قوی بگذارید
ADMIN_PASSWORD=change-me-please

# عنوان مهمانی (اختیاری). اگر تعریف نشود، خط عنوان بزرگ نمایش داده نمی‌شود.
# PARTY_TITLE=مهمانی خداحافظی

# زیرعنوان. برای چند خطی‌شدن از «\n» بین خط‌ها استفاده کنید:
PARTY_SUBTITLE=چهارشنبه . هفدهم تیرماه . ساعت ۲۱ تا ۲۳ . رستوران باکس راویس\nلطفا سفارش غذای خود را برای کیفیت بهتر رویداد، همین‌جا ثبت کنید.
