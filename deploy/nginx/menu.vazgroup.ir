#     listen 443 ssl;
#     listen [::]:443 ssl;
#     http2 on;
#     server_name menu.vazgroup.ir;
#
#     ssl_certificate     /etc/letsencrypt/live/menu.vazgroup.ir/fullchain.pem;
#     ssl_certificate_key /etc/letsencrypt/live/menu.vazgroup.ir/privkey.pem;
